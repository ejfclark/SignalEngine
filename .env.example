# Copy to .env (never commit .env). The engine loads this file automatically.
# Same database the StockIngest app writes to (only needed for `ingest context`):
EDSTOCK_CONN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=<server>.database.windows.net,1433;DATABASE=EdStock;UID=<user>;PWD=<password>;Connection Timeout=60
# Preferred stock/ETF price source (free key from tiingo.com; Yahoo used if unset):
#TIINGO_API_KEY=...
# Enables the daily fundamentals snapshot job:
#FMP_API_KEY=...
