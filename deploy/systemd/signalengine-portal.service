[Unit]
Description=SignalEngine signals portal (Flask via gunicorn)
Wants=network-online.target
After=network-online.target

[Service]
User=signalengine
WorkingDirectory=/opt/signalengine
EnvironmentFile=/etc/signalengine/signalengine.env
ExecStart=/opt/signalengine/.venv/bin/gunicorn -b 127.0.0.1:8050 -w 2 signalengine.portal:app
Restart=on-failure

[Install]
WantedBy=multi-user.target
