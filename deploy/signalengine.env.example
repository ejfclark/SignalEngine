# /etc/signalengine/signalengine.env  (chmod 600)
# Only needed for `ingest context` / `export-parquet` (SQL bridge):
EDSTOCK_CONN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=<server>.database.windows.net,1433;DATABASE=EdStock;UID=<user>;PWD=<password>;Connection Timeout=60
# Optional but recommended (free key from tiingo.com; used instead of Yahoo when set):
#TIINGO_API_KEY=...
# Optional (enables the fundamentals job):
#FMP_API_KEY=...

# Portal login (generate with: python -m signalengine.portal --make-hash):
#PORTAL_USER=...
#PORTAL_PASSWORD_HASH=...
#PORTAL_SECRET_KEY=...
