{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open IONOS SignalEngine tunnel",
      "type": "shell",
      "command": "ssh",
      "args": ["-N", "ionos-se"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false
      },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "."
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
